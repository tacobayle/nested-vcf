    mkdir -p /etc/vault.d
    mv /etc/vault.d/vault.hcl /etc/vault.d/vault.hcl.ori
    export VAULT_ADDR="https://127.0.0.1:8200"
    vault_config='
    storage "file" {
      path    = "/opt/vault/data"
    }
      listener "tcp" {
        address     = "0.0.0.0:8200"
        tls_disable = "false"
        tls_cert_file = "/opt/vault/tls/tls.crt"
        tls_key_file = "/opt/vault/tls/tls.key"
      }
      ui = true
      api_addr = "https://10.6.248.70:8200"'
    echo "${vault_config}" | tee /etc/vault.d/vault.hcl
    systemctl start vault
    systemctl enable vault
    # vault server -config /etc/vault.d/vault.hcl
    vault operator init -key-shares=1 -key-threshold=1 -tls-skip-verify -format json | tee /home/ubuntu/vault/secret.json
    vault operator unseal -tls-skip-verify $(jq -c -r .unseal_keys_hex[0] /home/ubuntu/vault/secret.json)
    vault login -tls-skip-verify $(jq -c -r .root_token /home/ubuntu/vault/secret.json)
    # root ca
    vault secrets enable -tls-skip-verify pki
    vault secrets tune -tls-skip-verify -max-lease-ttl=87600h "pki"
    vault write -tls-skip-verify -field=certificate pki/root/generate/internal common_name="vault.com" issuer_name="vault_demoavi" ttl=87600h > /home/ubuntu/vault/ca.crt
    vault write -tls-skip-verify pki/roles/role-pki-ca allow_any_name=true
    vault write -tls-skip-verify pki/config/urls issuing_certificates="https://10.6.248.70:8200/v1/role-pki-ca/ca" crl_distribution_points="https://10.6.248.70:8200/v1/${vault_pki_role_name}/crl"
    # intermediate ca
    vault secrets enable -tls-skip-verify -path=pki_int pki
    vault secrets tune -tls-skip-verify -max-lease-ttl=43800h pki_int
    vault write -tls-skip-verify -format=json pki_int/intermediate/generate/internal common_name="intermediate-vault.com" issuer_name="demoavi" | jq -r '.data.csr' | tee /home/ubuntu/vault/pki_intermediate.csr
    vault write -tls-skip-verify -format=json pki/root/sign-intermediate issuer_ref="vault_demoavi" csr=@/home/ubuntu/vault/pki_intermediate.csr format=pem_bundle ttl="43800h" | jq -r '.data.certificate' | tee
 /home/ubuntu/vault/pki_intermediate.cert.pem
    vault write -tls-skip-verify pki_int/intermediate/set-signed certificate=@/home/ubuntu/vault/pki_intermediate.cert.pem
    vault write -tls-skip-verify pki_int/roles/pki_intermediate_role issuer_ref="$(vault read -tls-skip-verify -field=default ${vault_pki_intermediate_role_name}/config/issuers)" allowed_domains="vcf9.lab" allow_subdomains=true max_ttl="1440h"